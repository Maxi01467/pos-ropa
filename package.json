{
  "name": "pos-ropa",
  "version": "0.1.3",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:web": "next dev --turbo",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:desktop\"",
    "desktop": "wait-on http://localhost:3000 && cross-env ELECTRON_RENDERER_URL=http://localhost:3000 electron .",
    "build": "next build --webpack",
    "prisma:generate": "prisma generate",
    "build:desktop": "npm run prisma:generate && npm run build && node scripts/prepare-desktop-build.cjs && electron-builder --win nsis",
    "release:desktop": "npm run prisma:generate && npm run build && node scripts/prepare-desktop-build.cjs && electron-builder --win nsis --publish always",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "migrate:productos": "tsx prisma/migrate-productos.ts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.1.0",
    "@heroui/theme": "^2.4.26",
    "@journeyapps/wa-sqlite": "^1.6.0",
    "@powersync/react": "^1.10.0",
    "@powersync/web": "^1.37.2",
    "@prisma/client": "^6.19.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "electron-updater": "^6.8.3",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "lenis": "^1.3.23",
    "lucide-react": "^0.577.0",
    "motion": "^12.39.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pdf-to-printer": "^5.7.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-barcode": "^1.6.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.posropa.desktop",
    "productName": "POS Ropa",
    "icon": "assets/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "Maxi01467",
        "repo": "pos-ropa"
      }
    ],
    "asar": true,
    "asarUnpack": [
      ".next/standalone/**/*",
      "prisma/**/*",
      "node_modules/pdf-to-printer/**/*"
    ],
    "files": [
      "assets/icon.ico",
      "assets/icon.png",
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/standalone/.next/**/*",
      ".next/standalone/.env",
      "prisma/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
