// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------
// 👥 PERSONAL Y ASISTENCIA
// ------------------------------------------------------
model User {
  id        String   @id @default(cuid())
  name      String
  pin       String   @default("1234") // Contraseña de acceso
  role      String   @default("STAFF") // ADMIN o STAFF
  active    Boolean  @default(true)
  deviceId  String?  @unique // Si en el futuro usan QR con celular

  openedSessions     CashSession[] @relation("OpenedSessions")
  closedSessions     CashSession[] @relation("ClosedSessions")
  countedSessions    CashSession[] @relation("CountedSessions")
  
  shifts    Shift[]
  sales     Sale[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Terminal {
  id        String   @id @default(cuid())
  name      String
  prefix    String   @unique
  deviceId  String   @unique
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Shift {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  
  checkIn    DateTime  @default(now())
  checkOut   DateTime?
  totalHours Decimal?
  notes      String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
}

// ------------------------------------------------------
// 💰 GESTIÓN DE CAJA (ARQUEO)
// ------------------------------------------------------
model CashSession {
  id             String    @id @default(cuid())
  
  // Quién abrió y quién cerró
  openedById     String
  openedBy       User      @relation("OpenedSessions", fields: [openedById], references: [id])
  closedById     String?
  closedBy       User?     @relation("ClosedSessions", fields: [closedById], references: [id])
  
  status         String    @default("OPEN") // OPEN, PENDING_COUNT, CLOSED

  openingDate    DateTime  @default(now())
  closingDate    DateTime?

  // Quién y cuándo hizo el arqueo (puede ser diferido)
  countedById    String?
  countedBy      User?     @relation("CountedSessions", fields: [countedById], references: [id])
  countingDate   DateTime?

  // Valores monetarios
  initialAmount  Decimal   // El "cambio" con el que se empieza
  expectedAmount Decimal?  // Lo que el sistema calcula que debería haber
  actualAmount   Decimal?  // Lo que el usuario contó físicamente
  difference     Decimal?  // Diferencia entre lo esperado y lo real

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  
  // Relaciones
  sales          Sale[]
  movements      CashMovement[]
}

model CashMovement {
  id           String      @id @default(cuid())
  sessionId    String
  session      CashSession @relation(fields: [sessionId], references: [id])
  
  amount       Decimal
  type         String      // INGRESO (ej: cambio extra), EGRESO (ej: pago correo)
  reason       String      // Descripción del movimiento
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
}

// ------------------------------------------------------
// 📦 INVENTARIO Y PRODUCTOS
// ------------------------------------------------------
model Supplier {
  id        String    @id @default(cuid())
  name      String
  phone     String?
  notes     String?
  
  stockMovements StockMovement[]  
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}

model Product {
  id             String   @id @default(cuid())
  name           String
  quickCreated   Boolean  @default(false)
  pendingReview  Boolean  @default(false)
  quickCreatedAt DateTime?
  quickCreatedByName String?
  quickCreatedByRole String?
  quickNotificationSeen Boolean @default(true)
  reviewedAt     DateTime?
  reviewedByName String?
  
  // Los dos precios que maneja el local
  priceNormal    Decimal  // Transferencia / Tarjeta
  priceWholesale Decimal  // Efectivo
  
  costPrice      Decimal? // Opcional para ver ganancias
  
  variants       ProductVariant[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  size           String   @default("Único")
  color          String   @default("Único")
  sku            String   @unique // El código de barras a imprimir
  stock          Int      @default(0) // Stock actual en mostrador
  
  movements      StockMovement[]
  saleItems      SaleItem[]
  barcodeAliases BarcodeAlias[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model StockMovement {
  id             String         @id @default(cuid())
  variantId      String
  variant        ProductVariant @relation(fields: [variantId], references: [id])
  
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])

  quantity       Int      // Ej: 10 (ingreso) o -2 (corrección)
  type           String   // INGRESO, AJUSTE, FALLA
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

// ------------------------------------------------------
// 🧾 VENTAS Y BOLETAS (TICKETS)
// ------------------------------------------------------
model Sale {
  id            String     @id @default(cuid())
  
  // Este es el número de Boleta físico que verá el cliente (Prefijo Caja + Secuencia, ej: C1-001)
  ticketNumber  String     @unique 
  
  total         Decimal
  paymentMethod String     // EFECTIVO, TRANSFERENCIA, MIXTO
  
  // Novedad: Guardamos el desglose exacto
  cashAmount     Decimal?  // Monto en billetes
  transferAmount Decimal?  // Monto a la cuenta
  
  userId        String     // Quién hizo la venta
  user          User       @relation(fields: [userId], references: [id])
  
  items         SaleItem[]

  // Relación con la caja activa
  cashSessionId String?      // Opcional por si haces ventas fuera de una sesión
  cashSession   CashSession? @relation(fields: [cashSessionId], references: [id])
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
}

model SaleItem {
  id               String         @id @default(cuid())
  saleId           String
  sale             Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id])
  
  quantity         Int
  priceAtTime      Decimal        // Fundamental: El precio congelado al momento de la venta
  priceType        String         // NORMAL o WHOLESALE
  
  // Control para devoluciones futuras
  returnedQuantity Int            @default(0) 
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
}

// ------------------------------------------------------
// 🏷️ CÓDIGOS DE BARRAS ALTERNATIVOS (MIGRACIÓN)
// ------------------------------------------------------
// Permite que el sistema reconozca los códigos de barras viejos
// sin necesidad de re-etiquetar la mercadería.
model BarcodeAlias {
  id        String         @id @default(cuid())
  barcode   String         @unique // Código del sistema anterior
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
}
